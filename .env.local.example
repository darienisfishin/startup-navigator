# ─── AI ───────────────────────────────────────────────────────────────────────
# Set USE_REAL_AI=true to use Claude instead of mock responses
USE_REAL_AI=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# The verified sender address/domain in your Resend account
EMAIL_FROM=LaunchWise <reports@launch-pilot.com>

# ─── App ──────────────────────────────────────────────────────────────────────
# Used to build report deep-links in emails
NEXT_PUBLIC_APP_URL=https://launch-pilot.com
