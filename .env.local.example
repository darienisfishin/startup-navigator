# ─── AI ───────────────────────────────────────────────────────────────────────
# Set USE_REAL_AI=true to use Claude instead of mock responses
USE_REAL_AI=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Supabase (auth + report storage) ─────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — bypasses RLS. Used only in server-side webhook handlers. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# The verified sender address/domain in your Resend account
EMAIL_FROM=LaunchPilot <reports@launch-pilot.com>

# ─── Stripe (payments) ────────────────────────────────────────────────────────
# Test keys (safe for local dev). Production keys live in Vercel env vars only.
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Get this from https://dashboard.stripe.com/webhooks after creating an endpoint
# pointing to: https://your-domain.com/api/webhooks/stripe
# Listen for: checkout.session.completed
# For local testing use: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_TODO

# ─── App ──────────────────────────────────────────────────────────────────────
# Used to build report deep-links in emails
NEXT_PUBLIC_APP_URL=https://launch-pilot.com
